---
interface Props {
  envId: string;
  path?: string;
}

const { envId, path } = Astro.props;
---

<link rel="preconnect" href="https://twikoo.284628.xyz" />
<link rel="preconnect" href="https://cdn.jsdelivr.net" />

<div class="mt-8">
  <h2 class="mb-4 text-lg font-medium text-zinc-900 dark:text-zinc-100">评论</h2>
  <div 
    id="tcomment" 
    class="twikoo-container rounded-lg border p-4 dark:border-zinc-700"
    data-env-id={envId}
    data-path={path || 'auto'}
  >
    <div class="flex items-center justify-center py-8 text-zinc-500 dark:text-zinc-400">
      <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-500 mr-2"></div>
      正在加载评论...
    </div>
  </div>
</div>

<script is:inline>
  class TwikooLoader {
    constructor() {
      this.loaded = false;
      this.retryCount = 0;
      this.maxRetries = 10;
      this.retryDelay = 300;
      this.setupObserver();
    }

    setupObserver() {
      const container = document.getElementById('tcomment');
      if (!container) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.loaded) {
            this.loadTwikoo();
            observer.disconnect();
          }
        });
      }, {
        rootMargin: '100px'
      });

      observer.observe(container);
    }

    async loadTwikoo() {
      if (this.loaded) return;
      
      try {
        await this.loadScript('https://cdn.jsdelivr.net/npm/twikoo@1.6.32/dist/twikoo.all.min.js');
        this.loaded = true;
        await this.initTwikoo();
      } catch (error) {
        console.warn('Twikoo 加载失败，准备重试:', error);
        this.handleLoadError();
      }
    }

    loadScript(src) {
      return new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) {
          resolve();
          return;
        }

        const script = document.createElement('script');
        script.src = src;
        script.defer = true;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }

    async initTwikoo() {
      const container = document.getElementById('tcomment');
      if (!container) {
        console.warn('Twikoo 容器未找到');
        return;
      }

      const envId = container.getAttribute('data-env-id');
      const path = container.getAttribute('data-path');
      
      if (!envId) {
        this.showError('评论系统配置错误：缺少环境ID');
        return;
      }

      await this.waitForTwikoo();

      try {
        container.innerHTML = '';
        
        await window.twikoo.init({
          envId: envId,
          el: '#tcomment',
          path: path === 'auto' ? location.pathname : path,
          lang: 'zh-CN'
        });
        
        console.log('Twikoo 初始化成功');
      } catch (error) {
        console.error('Twikoo 初始化失败:', error);
        this.showError(`评论系统初始化失败：${error.message}`);
      }
    }

    waitForTwikoo() {
      return new Promise((resolve, reject) => {
        const checkTwikoo = () => {
          if (typeof window.twikoo !== 'undefined') {
            resolve();
          } else if (this.retryCount < this.maxRetries) {
            this.retryCount++;
            setTimeout(checkTwikoo, this.retryDelay);
          } else {
            reject(new Error('Twikoo 脚本加载超时'));
          }
        };
        checkTwikoo();
      });
    }

    handleLoadError() {
      if (this.retryCount < this.maxRetries) {
        setTimeout(() => {
          this.retryCount++;
          this.loadTwikoo();
        }, this.retryDelay * this.retryCount);
      } else {
        this.showError('评论系统加载失败，请刷新页面重试');
      }
    }

    showError(message) {
      const container = document.getElementById('tcomment');
      if (container) {
        container.innerHTML = `
          <div class="text-center py-8 text-red-500 dark:text-red-400">
            <svg class="mx-auto mb-2 h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="mb-2">${message}</p>
            <button 
              onclick="location.reload()" 
              class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-md text-sm transition-colors"
            >
              重新加载
            </button>
          </div>
        `;
      }
    }

    reinit() {
      this.loaded = false;
      this.retryCount = 0;
      this.setupObserver();
    }
  }

  let twikooLoader;

  function initTwikooLoader() {
    twikooLoader = new TwikooLoader();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTwikooLoader);
  } else {
    initTwikooLoader();
  }

  document.addEventListener('astro:after-swap', () => {
    console.log('页面切换，重新初始化 Twikoo');
    if (twikooLoader) {
      twikooLoader.reinit();
    } else {
      setTimeout(initTwikooLoader, 100);
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (!document.hidden && twikooLoader && !twikooLoader.loaded) {
      const container = document.getElementById('tcomment');
      if (container && container.children.length === 0) {
        twikooLoader.loadTwikoo();
      }
    }
  });
</script>

<style is:global>
  .twikoo-container {
    font-family: inherit;
    min-height: 200px;
    contain: layout style paint;
  }
  
  .dark .twikoo-container {
    background-color: transparent;
  }
  
  .dark .tk-content textarea,
  .dark .tk-input input {
    background-color: rgb(39 39 42) !important;
    border-color: rgb(63 63 70) !important;
    color: rgb(228 228 231) !important;
  }
  
  .dark .tk-content textarea:focus,
  .dark .tk-input input:focus {
    border-color: rgb(96 165 250) !important;
  }
  
  .dark .tk-submit {
    background-color: rgb(24 24 27) !important;
    border-color: rgb(63 63 70) !important;
    color: rgb(228 228 231) !important;
  }
  
  .dark .tk-submit:hover {
    background-color: rgb(39 39 42) !important;
  }
  
  .dark .tk-comment,
  .dark .tk-replies-wrap {
    background-color: transparent !important;
    border-color: rgb(63 63 70) !important;
  }
  
  .dark .tk-comment .tk-main {
    color: rgb(228 228 231) !important;
  }
  
  .dark .tk-comment .tk-meta span {
    color: rgb(161 161 170) !important;
  }
  
  .dark .tk-comment a {
    color: rgb(96 165 250) !important;
  }
  
  .dark .tk-comment a:hover {
    color: rgb(147 197 253) !important;
  }
  
  .dark .tk-owo-container {
    background-color: rgb(39 39 42) !important;
    border-color: rgb(63 63 70) !important;
  }
  
  .dark .tk-tag,
  .dark .tk-extras {
    color: rgb(161 161 170) !important;
  }
  
  .tk-comment,
  .tk-content,
  .tk-input {
    font-family: 'Geist', system-ui, sans-serif !important;
  }
  
  .tk-content textarea,
  .tk-input input,
  .tk-submit,
  .tk-comment,
  .tk-owo-container {
    border-radius: 0.5rem !important;
  }
  
  .tk-comment {
    margin-bottom: 1rem !important;
  }
  
  .dark .tk-loading {
    color: rgb(161 161 170) !important;
  }
  
  .animate-spin {
    animation: spin 1s linear infinite;
    will-change: transform;
  }
  
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .tk-comment .tk-avatar img {
    loading: lazy;
    decoding: async;
  }
</style>